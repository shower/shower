{
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"workspaces": [
		"packages/*",
		"shwr.me"
	],
	"scripts": {
		"prepare": "git config core.hooksPath .githooks",
		"dev:shower": "npm run dev --workspace=packages/shower",
		"dev:ribbon": "npm run dev --workspace=packages/ribbon",
		"dev:material": "npm run dev --workspace=packages/material",
		"build:core": "npm run build --workspace=packages/core",
		"build:shwr.me": "npm run build --workspace=shwr.me",
		"lint": "editorconfig-checker && eslint && stylelint 'packages/{material,ribbon}/styles/**/*.css'",
		"test": "npm run lint && npm run test:cli && npm run test:core",
		"test:cli": "npm test --workspace=packages/cli",
		"test:core": "npm test --workspace=packages/core"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"editorconfig-checker": "^6.1.1",
		"eslint": "^10.0.3",
		"globals": "^17.4.0",
		"rollup": "^4.59.0",
		"stylelint": "^17.4.0",
		"stylelint-config-pepelsbey": "^1.2.0",
		"stylelint-order": "^8.1.1",
		"vite": "^8.0.0"
	}
}
