{
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"workspaces": [
		"packages/*",
		"shwr.me"
	],
	"scripts": {
		"prepare": "git config core.hooksPath .githooks",
		"dev:shower": "npm run dev --workspace=packages/shower",
		"dev:ribbon": "npm run dev --workspace=packages/ribbon",
		"dev:material": "npm run dev --workspace=packages/material",
		"build": "npm run build --workspace=packages/core",
		"test": "npm run test:lint && npm run test:packages",
		"test:lint": "editorconfig-checker && eslint && stylelint 'packages/{material,ribbon}/styles/**/*.css'",
		"test:packages": "npm test --workspaces --if-present",
		"test:e2e": "npm run test:e2e --workspace=packages/core"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"editorconfig-checker": "^6.1.1",
		"eslint": "^10.0.3",
		"globals": "^17.4.0",
		"rollup": "^4.59.0",
		"stylelint": "^17.4.0",
		"stylelint-config-pepelsbey": "^1.2.0",
		"stylelint-order": "^8.1.1",
		"vite": "^8.0.0"
	}
}
